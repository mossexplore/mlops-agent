WISE_ENV=production
WISE_APP_NAME=Wise MLOps Agent
WISE_APP_VERSION=1.0
WISE_AGENT_DB_PATH=/app/data/agent.db
WISE_AUTH_ENABLED=true
WISE_AUTH_SECRET=replace-with-a-long-random-secret
WISE_ADMIN_USERNAME=admin
WISE_ADMIN_PASSWORD=replace-with-a-strong-password
WISE_SESSION_TTL_SECONDS=86400
WISE_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
